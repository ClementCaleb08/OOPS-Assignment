#include <iostream>
using namespace std;

class Shape {
public:
    virtual void area() {
        cout << "Area calculation\n";
    }
};

class Square : public Shape {
public:
    void area() {
        cout << "Square area\n";
    }
};

class Circle : public Shape {
public:
    void area() {
        cout << "Circle area\n";
    }
};

int main() {
    Shape* s;

    Square sq;
    Circle c;

    s = &sq;
    s->area();

    s = &c;
    s->area();
}
